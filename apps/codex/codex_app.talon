app: codex
-

tag(): user.command_search
tag(): terminal

# General
settings open: key(cmd-,)
folder open | file open folder: key(cmd-o)
file hunt: key(cmd-p)
shortcuts open: key(cmd-shift-/)
go back: key(cmd-[)
go forward: key(cmd-])
bar (open | close | switch): key(cmd-b)
bar right [open | close | switch]: key(cmd-alt-b)
files open: key(cmd-shift-e)
[browser] tab new: key(cmd-t)
tab (close | clothes): key(cmd-w)
browser open: key(cmd-shift-b)
(diff | review) open: key(ctrl-shift-g)
panel (open | close | switch): key(cmd-j)
(terminal | shell) open | panel (terminal | shell): key(ctrl-`)
(terminal | shell) clear: key(ctrl-l)

# Thread
thread new: key(cmd-n)
thread quick: key(cmd-alt-n)
thread hunt: key(cmd-g)
find: key(cmd-f)
thread last: key(cmd-shift-[)
thread next: key(cmd-shift-])
thread archive: key(cmd-shift-a)
thread pin: key(cmd-alt-p)
thread rename: key(cmd-alt-r)
thread <number_small>: key("cmd-{number_small}")

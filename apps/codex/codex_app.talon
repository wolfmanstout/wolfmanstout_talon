app: codex
-
tag(): user.command_search
tag(): terminal

# General
settings show: key(cmd-,)
folder open: key(cmd-o)
file hunt: key(cmd-p)
go back: key(cmd-[)
go forward: key(cmd-])
bar (hide | show | switch): key(cmd-b)
tab new: key(cmd-t)
browser (hide | show | switch): key(cmd-shift-b)
diff (hide | show | switch): key(cmd-alt-b)
(terminal | shell) (hide | show | switch): key(cmd-j)
(terminal | shell) clear: key(ctrl-l)

# Thread
thread new: key(cmd-n)
thread quick: key(cmd-alt-n)
thread hunt: key(cmd-g)
find: key(cmd-f)
thread last: key(cmd-shift-[)
thread next: key(cmd-shift-])
thread archive: key(cmd-shift-a)
thread pin: key(cmd-alt-p)
